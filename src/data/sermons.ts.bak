export interface Announcement {
  id: number;
  title: string;
  date: string;
  type: 'bulletin' | 'sermon' | 'devotional';
  pdfUrl: string;
}

export interface SermonData {
  announcements: Announcement[];
}

// Import JSON directly
import rawData from '../../public/sermons/data/announcements.json';

export const sermonData: SermonData = rawData as SermonData;

// Helper: get latest announcements
export function getLatestAnnouncements(limit = 5): Announcement[] {
  return [...sermonData.announcements]
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, limit);
}

// Helper: get by type
export function getAnnouncementsByType(
  type: Announcement['type']
): Announcement[] {
  return sermonData.announcements.filter((a) => a.type === type);
}